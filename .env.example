# Copy to `.env` or `.env.local` and restart Expo. Values are inlined into the client bundle.
# Never commit real production keys.

# Optional fallback when the user has not saved an API key in AI settings (dev / internal builds).
# EXPO_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-...
# EXPO_PUBLIC_OPENAI_API_KEY=sk-...
